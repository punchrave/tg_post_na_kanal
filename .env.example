TG_API_ID=123456
TG_API_HASH=put_your_api_hash_here

# Optional. If omitted, Telethon will ask for the phone on first login.
TG_PHONE=+10000000000

# Telegram folder/filter title or numeric filter id.
TG_FOLDER=My folder

# Optional defaults.
TG_SESSION=telegram_autoposter
TG_PARSE_MODE=md
TG_DELAY_MIN=2
TG_DELAY_MAX=6

# ── telegram_channel_monitor.py ──────────────────────────────────
# Channel to monitor (username or link).
TG_MONITOR_CHANNEL=@channel_username

# Fixed (static) ID printed on every output line.
TG_MONITOR_STATIC_ID=12345

# Poll interval in seconds (how often to check for new posts).
TG_MONITOR_POLL=15

# Emotion ID used when a post has no reactions (default: 343 = ❤).
TG_MONITOR_FALLBACK_ID=343
